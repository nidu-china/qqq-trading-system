# ==================== 交易模式与实盘授权 ====================
# paper=模拟交易，replay=历史回放，live=真实下单。
TRADING_MODE=paper
ACCOUNT_ID=
# live 模式必须填写 I_UNDERSTAND_LIVE_TRADING:账户ID。
LIVE_TRADING_ACK=
UNDERLYING_SYMBOL=QQQ.US

# ==================== MySQL ====================
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=root-change-me
# VS Code 本地运行使用 127.0.0.1；特殊字符密码需要 URL 编码。
DATABASE_URL=mysql+asyncmy://qqq:change-me@127.0.0.1:3306/qqq?charset=utf8mb4

# ==================== 数据与服务 ====================
DATA_DIR=./data/market
REPORT_DIR=./data/reports
API_HOST=127.0.0.1
API_PORT=8000
# 设置后所有非健康检查端点需提供 Authorization: Bearer <token>。留空则不鉴权。
API_TOKEN=
LOG_LEVEL=INFO
SCHEDULER_POLL_SECONDS=1

# ==================== Longbridge ====================
LONGBRIDGE_CLIENT_ID=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
LONGBRIDGE_PRINT_QUOTE_PACKAGES=false
# 历史行情等SDK请求的最长等待秒数，超时会输出明确的请求信息。
LONGBRIDGE_REQUEST_TIMEOUT_SECONDS=60

# ==================== 交易时间（美东） ====================
ENTRY_START=09:45:00
ENTRY_END=12:00:00
FORCED_CLOSE=12:15:00
REPORT_AT=16:15:00
# 完全平仓后冷却分钟数；每天最多开仓次数。
COOLDOWN_MINUTES=5
MAX_TRADES_PER_DAY=5

# ==================== QQQ 5分钟信号参数 ====================
# MACD 快线、慢线、信号线周期。
MACD_FAST=5
MACD_SLOW=10
MACD_SIGNAL=3
# 参数组合格式：快线,慢线,信号线；多组之间使用英文分号分隔。
MACD_BACKTEST_COMBINATIONS=8,17,9;6,13,5;5,10,3
# 布林带周期和标准差倍数；信号要求收盘价真正穿越上轨或下轨。
BOLLINGER_PERIOD=20
BOLLINGER_STDDEV=2
# 当前成交量必须大于此前 20 根完整K线均量的 1.2 倍。
VOLUME_AVERAGE_PERIOD=20
MIN_VOLUME_RATIO=1.2
# Call 要求 RSI<70，Put 要求 RSI>30。
RSI_PERIOD=14
RSI_CALL_MAX=70
RSI_PUT_MIN=30
# Call 选择 QQQ现价+2，Put 选择 QQQ现价-2 附近的当日到期行权价。
STRIKE_OFFSET=2

# ==================== VIX/VXN 波动率状态过滤 ====================
VOLATILITY_FILTER_ENABLED=true
VOLATILITY_SYMBOL=.VIX.US
VOLATILITY_LOOKBACK_DAYS=20
VOLATILITY_MAX_STALENESS_MINUTES=10
VOLATILITY_RISK_OFF_PERCENTILE=0.80
VOLATILITY_RECOVERY_PERCENTILE=0.65
VOLATILITY_RISE_5M=0.02
VOLATILITY_RISE_15M=0.03
VOLATILITY_FALL_5M=-0.02
VOLATILITY_FALL_15M=-0.03
VOLATILITY_SHOCK_5M=0.08
VOLATILITY_SHOCK_15M=0.12

# ==================== 报价与流动性 ====================
MAX_QUOTE_AGE_SECONDS=2
MAX_SPREAD_RATIO=0.10
MAX_SPREAD_ABSOLUTE=0.20
MIN_OPEN_INTEREST=100
MIN_OPTION_VOLUME=10

# ==================== 仓位与风控 ====================
RISK_PER_TRADE=0.005
DAILY_LOSS_LIMIT=0.02
STOP_LOSS_PCT=0.25
TAKE_PROFIT_1_PCT=0.50
TAKE_PROFIT_2_PCT=1.00
MAX_PREMIUM_FRACTION=0.05
MAX_CONTRACTS=10
FEE_PER_CONTRACT=1.50
SLIPPAGE_PER_CONTRACT=5.00

# ==================== 订单执行 ====================
ORDER_TIMEOUT_SECONDS=6
ENTRY_REPRICES=2
MAX_ENTRY_SLIPPAGE_PCT=0.02

# ==================== 日志 ====================
# 日志目录，日志文件按天自动轮转保留30天
LOG_DIR=logs
LOG_LEVEL=INFO

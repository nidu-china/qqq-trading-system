# ==================== 交易模式与实盘授权 ====================
# paper = 模拟交易（产生信号并虚拟执行，不真实下单）
# replay = 历史回放（CLI 回测专用，引擎以回放模式运行）
# live = 真实下单（信号触发后向券商发送真实订单）
TRADING_MODE=paper
# Longbridge 账户 ID，用于查询持仓/资金/下单。
ACCOUNT_ID=
# live 模式必须设置为 "I_UNDERSTAND_LIVE_TRADING:你的账户ID" 才允许启动，防止误操作。
LIVE_TRADING_ACK=
# 标的代码：策略监控的 ETF，默认 QQQ.US（纳斯达克100 ETF）。
UNDERLYING_SYMBOL=QQQ.US

# ==================== MySQL ====================
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=root-change-me
# 数据库连接串。本地开发使用 127.0.0.1；Docker 部署改为容器名。密码特殊字符需 URL 编码。
DATABASE_URL=mysql+asyncmy://qqq:change-me@127.0.0.1:3306/qqq?charset=utf8mb4

# ==================== 数据与服务 ====================
# K线/期权数据的 Parquet 存储目录
DATA_DIR=./data/market
# 日报输出目录（含 HTML/JSON/Markdown/SVG）
REPORT_DIR=./data/reports
# API 监听地址和端口。0.0.0.0 允许外部访问，127.0.0.1 仅本机。
API_HOST=127.0.0.1
API_PORT=8000
# Bearer Token 鉴权。设置后所有非健康检查端点需提供 Authorization: Bearer <token>。留空不鉴权。
API_TOKEN=
# 主循环轮询间隔（秒）。越小响应越快，但 CPU 占用更高。
SCHEDULER_POLL_SECONDS=1

# ==================== Longbridge 券商 API ====================
# OAuth 模式（推荐）：只填 CLIENT_ID，首次启动时浏览器授权。
LONGBRIDGE_CLIENT_ID=
# 密钥模式：适合无浏览器的服务器环境，填写下面三个字段。
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
# 启动时在控制台打印当前数据权限表。
LONGBRIDGE_PRINT_QUOTE_PACKAGES=false
# 历史行情请求超时（秒），超时后输出明确错误信息辅助排查。
LONGBRIDGE_REQUEST_TIMEOUT_SECONDS=60

# ==================== 交易时间（美东 ET） ====================
# 允许开仓的时间窗口。在此窗口外即使产生信号也不会入场。
ENTRY_START=09:45:00
ENTRY_END=11:25:00
# 强制平仓时间。到时未平的持仓会以市价强制卖出。
FORCED_CLOSE=14:00:00
# 收盘后生成日报的时间。
REPORT_AT=16:15:00
# 完全平仓后冷却分钟数，防止频繁进出。
COOLDOWN_MINUTES=5
# 每天最多开仓次数（包含止损后重新开仓）。
MAX_TRADES_PER_DAY=2

# ==================== 状态机策略参数 ====================
# 系统采用 5 分钟 K 线进行策略判断，1 分钟 K 线用于精确执行。
# 阶段：
#   9:30-9:45   → 观察期（记录 ORH/ORL）
#   9:45-11:25  → 活跃交易期（趋势突破 + 反转入场）
#   11:25+      → 仓位管理期（只减仓不加仓）

# ── 技术指标参数 ──
# MACD 参数：快线、慢线、信号线周期。
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
# EMA 周期：9/20 均线用于趋势确认和回踩入场。
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=20
# ADX 周期：衡量趋势强度，>20 为趋势明确。
ADX_PERIOD=14
# ATR 周期：衡量波动幅度，用于止损计算。
ATR_PERIOD=14
# RVOL 回看天数：相对成交量基准。
RVOL_LOOKBACK_DAYS=20
# 开盘区间宽度回看天数：用于计算 OR 宽度百分位。
OR_WIDTH_LOOKBACK_DAYS=60

# ── 市场状态分类阈值 ──
# 趋势确认：RVOL 最低倍数（放量确认趋势）。
TREND_RVOL_MIN=1.1
# 趋势确认：ADX 最低值（趋势强度）。
TREND_ADX_MIN=20
# 震荡判定：ADX 低于此值 + 其他条件 → 判定为横盘震荡，停止开仓。
RANGE_ADX_MAX=18
# 追价保护：突破后价格偏离超过 ATR × 此倍数时放弃入场（防追高）。
CHASE_ATR_FACTOR=1.5

# 行权价偏移：Call 选 现价+偏移，Put 选 现价-偏移 的当日到期合约（0DTE）。
STRIKE_OFFSET=2

# ==================== VIX 波动率方向性过滤 ====================
# 启用后，根据 VIX 状态进行方向性过滤（而非简单暂停所有开仓）：
#   NORMAL      → CALL 和 PUT 均可开仓
#   RISK_OFF    → VIX 高位且持续上涨 → 仅允许 PUT（市场恐慌做空）
#   RECOVERY    → VIX 高位但开始回落 → 仅允许 CALL（恐慌消退做多）
#   SHOCK       → VIX 极端飙升 → 暂停所有方向（极端行情不参与）
#   UNAVAILABLE → VIX 数据不足 → 暂停所有方向（无法判断状态）
VOLATILITY_FILTER_ENABLED=true
# 波动率参考标的（CBOE VIX 指数）。
VOLATILITY_SYMBOL=.VIX.US
# 计算百分位排名时回看的交易日数。越大基线越稳定。
VOLATILITY_LOOKBACK_DAYS=20
# VIX 数据最大容忍滞后（分钟）。超过此值状态为 UNAVAILABLE。
VOLATILITY_MAX_STALENESS_MINUTES=10
# RISK_OFF 触发条件：VIX 处于历史 80% 分位以上 + 短期仍在上涨。
# 效果：仅允许 PUT（VIX 异常升高 = 市场在跌，适合做空）。
VOLATILITY_RISK_OFF_PERCENTILE=0.80
# RECOVERY 触发条件：VIX 处于历史 65% 分位以上 + 短期开始回落。
# 效果：仅允许 CALL（VIX 从高位回落 = 市场企稳，适合做多）。
VOLATILITY_RECOVERY_PERCENTILE=0.65
# RISK_OFF 短期涨幅阈值：5分钟涨 2% 或 15分钟涨 3% 判定 VIX 仍在上升。
VOLATILITY_RISE_5M=0.02
VOLATILITY_RISE_15M=0.03
# RECOVERY 短期回落阈值：5分钟跌 2% 或 15分钟跌 3% 判定 VIX 开始回落。
VOLATILITY_FALL_5M=-0.02
VOLATILITY_FALL_15M=-0.03
# SHOCK 阈值：5分钟涨 8% 或 15分钟涨 12% = 极端行情，暂停所有方向。
VOLATILITY_SHOCK_5M=0.08
VOLATILITY_SHOCK_15M=0.12

# ==================== 报价与流动性门槛 ====================
# 标的报价最大年龄（秒）。超过此值认为行情断连，拒绝信号。
MAX_QUOTE_AGE_SECONDS=2
# 期权 Bid-Ask 相对价差上限 (ask-bid)/mid。超过说明流动性差。
MAX_SPREAD_RATIO=0.10
# 期权 Bid-Ask 绝对价差上限（美元）。
MAX_SPREAD_ABSOLUTE=0.20
# 期权合约的最小未平仓量，低于说明合约过于冷门。
MIN_OPEN_INTEREST=100
# 期权合约的最小当日成交量。
MIN_OPTION_VOLUME=10

# ==================== 仓位与风控（R 体系） ====================
#
# ── 假设账户总权益 $100,000，以下为各参数示例 ──
#
# Paper 模式的初始账户资金（美元）。Live 模式从 Longbridge 实时获取。
PAPER_STARTING_EQUITY=100000
#
# ── R 基准 ──
# 单笔风险 = 权益 × RISK_PER_TRADE（即 1R）。
# 例：$100,000 × 0.0025 = $250 → 每笔最大亏 $250。
RISK_PER_TRADE=0.0025
#
# 当日累计 R 损失达到此值时停止交易。
# 例：DAILY_LOSS_LIMIT_R=2 → 累计亏 2R ($500) 后不再开仓。
DAILY_LOSS_LIMIT_R=2
#
# ── 止损（ATR 基准） ──
# 止损 = 最近摆动点 ± ATR × ATR_STOP_BUFFER（缓冲）。
# 例：swing_low=705.50, ATR=1.40, buffer=0.1 → stop=705.50 - 0.14 = 705.36
ATR_STOP_BUFFER=0.1
#
# 止损距离不得超过 ATR × MAX_STOP_ATR_RATIO，否则拒绝入场。
# 例：ATR=1.40, ratio=2.0 → 最大止损距离 $2.80。
MAX_STOP_ATR_RATIO=2.0
#
# ── 止盈（R 倍数） ──
# 第一止盈：获利达 1R 时卖出半仓，止损移至成本价。
TP1_R=1.0
# 第二止盈：获利达 2.5R 时清仓剩余。
TP2_R=2.5
#
# ── 过时仓位 ──
# 持仓超过 STALE_MINUTES 分钟且浮盈 < 0 时强制平仓。
# 防止资金被无方向仓位占用。
STALE_MINUTES=30
#
# ── 减仓时间 ──
# 到达此时间后减半仓位（美东 ET）。避免持仓到尾盘流动性下降。
REDUCE_AT=13:00:00
#
# 单笔买入期权的总权利金不超过账户权益的此比例。
# $100,000 × 0.05 = $5,000 → 最多一次花 $5,000 买期权。
MAX_PREMIUM_FRACTION=0.05
#
# 最大合约张数硬上限。无论仓位计算结果如何都不超过此数。
MAX_CONTRACTS=10
#
# 每张合约预估手续费（美元）。仓位计算时从可用金额中扣除。
FEE_PER_CONTRACT=1.50
#
# 每张合约滑点缓冲（美元）。期权流动性差时实际成交价可能偏高。
SLIPPAGE_PER_CONTRACT=5.00

# ==================== 订单执行 ====================
# 限价单等待成交超时（秒）。超时后尝试追价或放弃。
ORDER_TIMEOUT_SECONDS=6
# 入场追价次数。首单未成交后最多再追 N 次，每次提高限价。
ENTRY_REPRICES=2
# 最大追价幅度（相对首单限价）。0.02 = 最多加价2%。
MAX_ENTRY_SLIPPAGE_PCT=0.02

# ==================== 日志 ====================
# 日志输出目录。日志文件按天自动轮转，保留最近30天。
LOG_DIR=logs
# 日志级别：DEBUG / INFO / WARNING / ERROR。DEBUG 会输出账户快照等详细信息。
LOG_LEVEL=INFO
